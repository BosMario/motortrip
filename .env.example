# URL ฐานของ Worker กลุ่มทริป (ไม่ต้องมี /api ต่อท้าย)
# - dev:  ปล่อยว่างไว้ก็ได้ แอปจะ fallback ไป ws://localhost:8787 อัตโนมัติเมื่อรันบน localhost
#         หรือกำหนดเอง เช่น VITE_GROUP_WS=ws://localhost:8787
# - prod: ใส่โดเมน Worker ที่ deploy แล้ว เช่น
#         VITE_GROUP_WS=wss://moto-trip-group.<your-subdomain>.workers.dev
VITE_GROUP_WS=
